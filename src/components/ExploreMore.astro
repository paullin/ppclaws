---
interface Category {
  title: string;
  description: string;
  href: string;
  iconHtml?: string;
}

interface Props {
  title?: string;
  categories: Category[];
}

const { title = "探索其他分类", categories } = Astro.props;
---

<section class="pt-16 border-t border-gray-200 dark:border-astro-border">
  <h2 class="text-2xl font-bold tracking-tight mb-6">{title}</h2>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
    {
      categories.map((category) => (
        <a 
          href={category.href} 
          class="group flex items-center gap-4 p-5 rounded-xl border border-gray-200 dark:border-astro-border hover:border-astro-accent transition-all hover:shadow-lg bg-white dark:bg-astro-card"
        >
          <div class="w-12 h-12 rounded-lg bg-astro-accent/10 text-astro-accent flex items-center justify-center group-hover:scale-110 transition-transform">
            {category.iconHtml ? (
              <Fragment set:html={category.iconHtml} />
            ) : (
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><line x1="3" x2="21" y1="9" y2="9"/><line x1="9" x2="9" y1="21" y2="9"/></svg>
            )}
          </div>
          <div class="flex-1">
            <div class="text-base font-bold group-hover:text-astro-accent transition-colors text-gray-900 dark:text-white">
              {category.title}
            </div>
            <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">
              {category.description}
            </div>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-gray-400 group-hover:text-astro-accent transition-transform group-hover:translate-x-1">
            <path d="m9 18 6-6-6-6"/>
          </svg>
        </a>
      ))
    }
  </div>
</section>