---
interface Props {
  title: string;
  description: string;
  author?: string;
  date?: string | Date;
  tags?: string[];
  coverImage?: string;
  cover_theme?: string;
  cover_text?: string;
  badge?: string;
  isFeatured?: boolean;
  lang?: string;
}

const { title, description, author, date, tags, coverImage, cover_theme, cover_text, badge, isFeatured = false, lang = "en" } = Astro.props;

// Format date if provided
const formattedDate = date 
  ? new Date(date).toLocaleDateString('zh-CN', {
      year: 'numeric',
      month: '2-digit',
      day: '2-digit'
    }).replace(/\//g, '-')
  : undefined;

// Badge color logic for Article Header
const badgeStyles: Record<string, string> = {
    FREE: "bg-emerald-50 dark:bg-emerald-500/10 text-emerald-700 dark:text-emerald-400 border-emerald-100 dark:border-emerald-500/20",
    PAID: "bg-orange-50 dark:bg-orange-500/10 text-orange-700 dark:text-orange-400 border-orange-100 dark:border-orange-500/20",
    DEFAULT: "bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300 border-gray-200 dark:border-gray-700"
};

let badgeKey = "DEFAULT";
if (badge) {
    if (badge.toUpperCase() === "FREE" || badge === "免费") badgeKey = "FREE";
    else if (badge.toUpperCase() === "PAID" || badge === "付费") badgeKey = "PAID";
}
const currentBadgeStyle = badge ? (badgeStyles[badgeKey] || badgeStyles.DEFAULT) : "";

import { themeMap } from './SkillCard.astro';

const getTheme = (themeStr?: string) => {
    if (themeStr && themeMap[themeStr]) return themeMap[themeStr];
    // Simple stable randomizer based on title length
    const themes = Object.keys(themeMap);
    const index = (title.length) % themes.length;
    return themeMap[themes[index]];
};

const currentTheme = getTheme(cover_theme);

// Format cover text for detail page banner
let displayCoverText = title;
if (cover_text) {
    displayCoverText = cover_text.replace(' ', '<br>');
} else {
    const words = title.split(' ');
    if (words.length >= 2) {
        displayCoverText = words.slice(0, 2).join('<br>');
    }
}

const getInitials = (text: string) => {
    return text.replace(/<[^>]*>?/gm, ' ')
               .split(' ')
               .filter(w => w.length > 0)
               .map(w => w[0])
               .join('')
               .substring(0, 2)
               .toUpperCase();
};
const displayInitials = getInitials(cover_text || title);
---

<section class="space-y-8">
  {currentTheme ? (
    <div class={`relative aspect-video w-full rounded-2xl overflow-hidden border border-gray-200 dark:border-zinc-800 shadow-sm transition-colors ${currentTheme.bg}`}>
        <div class={`absolute -top-12 -right-12 text-[15rem] font-black select-none leading-none tracking-tighter transition-colors ${currentTheme.textBg}`}>
            {displayInitials}
        </div>
        <div class="absolute inset-0 flex flex-col justify-end p-8 sm:p-12">
            <h1 class={`text-5xl sm:text-6xl font-bold relative z-10 leading-snug tracking-wide transition-colors ${currentTheme.text}`} set:html={displayCoverText} />
        </div>
        
        {isFeatured && (
          <div class="absolute top-6 left-6 z-20 flex items-center justify-center w-12 h-12 rounded-full bg-white/90 dark:bg-gray-900/90 shadow-sm border border-gray-100 dark:border-gray-800 backdrop-blur-sm" title={lang === 'zh' ? '精选' : 'Featured'}>
              <svg class="w-6 h-6 text-red-500 fill-red-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
          </div>
        )}

        {badge && (
          <div class={`absolute top-6 right-6 z-20 px-3 py-1.5 text-sm font-bold rounded-lg border ${currentBadgeStyle} backdrop-blur-sm bg-white/80 dark:bg-zinc-900/80 uppercase tracking-wider`}>
              {badge}
          </div>
        )}
    </div>
  ) : coverImage && (
    <div class="relative aspect-video w-full rounded-2xl overflow-hidden border border-gray-200 dark:border-astro-border shadow-lg">
      <img src={coverImage} alt={title} class="w-full h-full object-cover" />
      
      {isFeatured && (
        <div class="absolute top-4 left-4 z-10 flex items-center justify-center w-10 h-10 rounded-full bg-white/90 dark:bg-gray-900/90 shadow-sm border border-gray-100 dark:border-gray-800 backdrop-blur-sm" title={lang === 'zh' ? '精选' : 'Featured'}>
            <svg class="w-5 h-5 text-red-500 fill-red-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
        </div>
      )}

      {badge && (
        <div class={`absolute top-4 right-4 z-10 px-3 py-1.5 text-sm font-bold rounded-lg border ${currentBadgeStyle} backdrop-blur-sm bg-white/80 dark:bg-gray-900/80 uppercase tracking-wider`}>
            {badge}
        </div>
      )}
    </div>
  )}

  <div class="space-y-4">
    <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl">{title}</h1>
    
    <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
      {author && (
        <div class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span>{author}</span>
        </div>
      )}
      
      {formattedDate && (
        <div class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
          <span>{formattedDate}</span>
        </div>
      )}
      
      {tags && tags.length > 0 && (
        <div class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/><circle cx="7.5" cy="7.5" r=".5" fill="currentColor"/></svg>
          <span>{tags.join(' / ')}</span>
        </div>
      )}
    </div>
    
    <p class="text-xl text-gray-600 dark:text-gray-400 leading-relaxed">
      {description}
    </p>
  </div>
</section>