---
interface Props {
    title: string;
    subtitle?: string;
    moreLink?: string;
    moreText?: string;
}

const { title, subtitle, moreLink, moreText = "浏览更多" } = Astro.props;
const normalizedMoreText = moreText.trim().toLowerCase();
const genericMoreTexts = new Set(["more", "browse more", "view all", "更多", "浏览更多", "查看更多", "查看全部"]);
const isGenericMoreText = genericMoreTexts.has(normalizedMoreText);
const isChineseTitle = /[\u3400-\u9fff]/.test(title);
const descriptiveMoreText = isGenericMoreText
    ? (isChineseTitle ? `查看更多${title}` : `${moreText} ${title}`)
    : moreText;
---

<div class="flex justify-between items-end mb-6 pb-4 border-b border-gray-200 dark:border-astro-border gap-4">
    <div>
        <h2 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">
            {title}
        </h2>
        {subtitle && (
            <p class="text-gray-500 dark:text-gray-400 mt-1 text-sm">
                {subtitle}
            </p>
        )}
    </div>
    {moreLink && (
        <a 
            href={moreLink} 
            class="text-sm font-medium text-violet-700 dark:text-violet-300 hover:underline flex items-center gap-1"
            aria-label={descriptiveMoreText}
        >
            {descriptiveMoreText}
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14" />
                <path d="m12 5 7 7-7 7" />
            </svg>
        </a>
    )}
</div>
