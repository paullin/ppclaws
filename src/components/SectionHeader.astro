---
interface Props {
    title: string;
    subtitle?: string;
    moreLink?: string;
    moreText?: string;
}

const { title, subtitle, moreLink, moreText = "浏览更多" } = Astro.props;
---

<div class="flex flex-col md:flex-row md:items-end justify-between mb-6 gap-4">
    <div class="space-y-1.5">
        <h2 class="text-2xl font-bold tracking-tight text-slate-900 dark:text-white mb-0">
            {title}
        </h2>
        {subtitle && (
            <p class="text-[15px] text-slate-500 dark:text-slate-400">
                {subtitle}
            </p>
        )}
    </div>
    {moreLink && (
        <a 
            href={moreLink} 
            class="text-[14px] text-primary hover:text-primary-hover font-medium flex items-center gap-1 transition-colors duration-200"
        >
            {moreText}
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m9 18 6-6-6-6"/>
            </svg>
        </a>
    )}
</div>
