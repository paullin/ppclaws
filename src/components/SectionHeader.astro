---
interface Props {
    title: string;
    subtitle?: string;
    moreLink?: string;
    moreText?: string;
}

const { title, subtitle, moreLink, moreText = "浏览更多" } = Astro.props;
---

<div class="flex justify-between items-end mb-6 gap-4">
    <div>
        <h2 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">
            {title}
        </h2>
        {subtitle && (
            <p class="text-gray-500 dark:text-gray-400 mt-1 text-sm">
                {subtitle}
            </p>
        )}
    </div>
    {moreLink && (
        <a 
            href={moreLink} 
            class="text-sm font-medium text-primary hover:underline flex items-center gap-1"
        >
            {moreText}
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="m9 18 6-6-6-6" />
            </svg>
        </a>
    )}
</div>
