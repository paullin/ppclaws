---
interface Props {
  items: {
    label: string;
    href?: string;
  }[];
}

const { items } = Astro.props;
---

<nav class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 flex-wrap">
  <a href="/" class="hover:text-astro-accent transition-colors">首页</a>
  {
    items.map((item, index) => (
      <>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
          <path d="m9 18 6-6-6-6"/>
        </svg>
        {item.href ? (
          <a
            href={item.href}
            class={`hover:text-astro-accent transition-colors ${
              index === items.length - 1 ? 'font-medium text-gray-900 dark:text-white' : ''
            }`}
          >
            {item.label}
          </a>
        ) : (
          <span class="text-gray-900 dark:text-white font-medium">{item.label}</span>
        )}
      </>
    ))
  }
</nav>