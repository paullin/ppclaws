---
// Imports
import {
    getLangFromUrl,
    useTranslations,
    useTranslatedPath,
} from "@i18n/utils";
import { Image } from "astro:assets";
import navigationData from "@data/navigationData";
import logo from "@assets/logo.webp";
import LanguagePicker from "./LanguagePicker.astro";
import Search from "astro-pagefind/components/Search";

// Translations
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const searchLabel = lang === "zh" ? "搜索" : "Search";
const themeLabel = lang === "zh" ? "暗黑模式" : "Theme";
---

<header class="sticky top-0 z-40 w-full backdrop-blur-md bg-white/80 dark:bg-[#0d0f14]/80 border-b border-gray-200 dark:border-astro-border" role="banner">
    <!-- Mobile menu toggle (CSS only) -->
    <input
        type="checkbox"
        id="mobile-menu-toggle"
        class="mobile-menu-checkbox hidden"
        aria-label="Toggle mobile menu"
    />

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
            <!-- Logo -->
            <div class="shrink-0 flex items-center z-10">
                <a
                    href={translatePath("/")}
                    class="flex items-center shrink-0 cursor-pointer hover:opacity-80 transition-opacity"
                    aria-label={t("main.title")}
                >
                    <Image
                        src={logo}
                        alt={t("main.title")}
                        loading="eager"
                        width={128}
                        height={128}
                        class="h-8 w-8 rounded-md mr-3 object-cover"
                    />
                    <span class="font-bold text-xl tracking-tight text-gray-900 dark:text-white">
                        PPClaws
                    </span>
                </a>
            </div>

            <!-- Desktop Navigation - Centered -->
            <nav class="hidden md:flex items-center space-x-1 lg:space-x-4 h-full" role="navigation" aria-label="Main navigation">
                <ul class="flex items-center gap-1 list-none m-0 p-0 h-full" role="menubar">
                    {
                        navigationData.map((item) => (
                            <li class="relative group h-full flex items-center" role="none">
                                <a
                                    href={translatePath(item.href)}
                                    class="px-3 py-2 text-[15px] font-bold text-gray-900 dark:text-gray-100 hover:text-primary transition-colors flex items-center gap-1 h-full"
                                    role="menuitem"
                                >
                                    {t(item.label)}
                                    {item.children?.length > 0 && (
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-100 group-hover:rotate-180 transition-transform duration-200"><path d="m6 9 6 6 6-6"/></svg>
                                    )}
                                </a>

                                {item.children?.length > 0 && (
                                    <ul
                                        class="absolute left-0 top-full min-w-[200px] w-max bg-white dark:bg-[#1e2330] border border-gray-200 dark:border-gray-800 rounded-lg shadow-lg py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform translate-y-[-10px] group-hover:translate-y-0 z-50"
                                        role="menu"
                                    >
                                        {item.children.map((child: any) => (
                                            <li role="none">
                                                <a
                                                    href={translatePath(child.href)}
                                                    class="block px-4 py-2.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-primary transition-colors font-medium"
                                                    role="menuitem"
                                                >
                                                    {t(child.label)}
                                                </a>
                                            </li>
                                        ))}
                                    </ul>
                                )}
                            </li>
                        ))
                    }
                </ul>
            </nav>

            <!-- Actions - Right -->
            <div class="flex items-center gap-2 z-10">
                <div class="hidden md:flex items-center space-x-2 lg:space-x-4">
                    <button
                        type="button"
                        class="p-2 rounded-md hover:bg-gray-200 dark:hover:bg-gray-800 transition-colors text-gray-900 dark:text-gray-100"
                        data-search-open
                        aria-label={searchLabel}
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    </button>

                    <button
                        type="button"
                        class="p-2 rounded-md hover:bg-gray-200 dark:hover:bg-gray-800 transition-colors text-gray-900 dark:text-gray-100"
                        data-theme-toggle
                        aria-label={themeLabel}
                    >
                        <svg class="theme-icon-moon dark:hidden" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"/></svg>
                        <svg class="theme-icon-sun hidden dark:block" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
                    </button>

                    <LanguagePicker />
                    <div class="h-6 w-px bg-gray-300 dark:bg-astro-border mx-2"></div>
                    <a href="#" class="p-2 rounded-md hover:bg-gray-200 dark:hover:bg-gray-800 transition-colors text-gray-900 dark:text-gray-100" title="GitHub" aria-label="GitHub">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
                    </a>
                </div>

                <!-- Mobile only actions -->
                <div class="flex items-center md:hidden gap-1">
                    <button
                        type="button"
                        class="p-2 text-black hover:opacity-70 dark:text-gray-300 dark:hover:text-white rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
                        data-search-open
                        aria-label={searchLabel}
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    </button>
                    
                    <label for="mobile-menu-toggle" class="p-2 text-black hover:opacity-70 dark:text-gray-400 dark:hover:text-white rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors cursor-pointer relative w-10 h-10 flex items-center justify-center">
                        <svg id="menu-icon" class="absolute transition-opacity duration-200" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
                        <svg id="close-icon" class="absolute opacity-0 transition-opacity duration-200" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" x2="6" y1="6" y2="18"/><line x1="6" x2="18" y1="6" y2="18"/></svg>
                    </label>
                </div>
            </div>
        </div>
    </div>

    <!-- Mobile Navigation Menu -->
    <div class="nav-main-mobile md:hidden max-h-0 overflow-hidden transition-all duration-300 ease-in-out bg-white/95 dark:bg-gray-900/95 backdrop-blur-lg border-t border-gray-100 dark:border-gray-800">
        <div class="px-4 pt-2 pb-6 space-y-1">
            {
                navigationData.map((item) => (
                    <div class="space-y-1">
                        <a
                            href={translatePath(item.href)}
                            class="block px-3 py-2 text-base font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg transition-colors"
                        >
                            {t(item.label)}
                        </a>
                        {item.children?.length > 0 && (
                            <div class="pl-4 space-y-1 border-l-2 border-gray-100 dark:border-gray-800 ml-3">
                                {item.children.map((child: any) => (
                                    <a
                                        href={translatePath(child.href)}
                                        class="block px-3 py-2 text-sm font-medium text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg transition-colors"
                                    >
                                        {t(child.label)}
                                    </a>
                                ))}
                            </div>
                        )}
                    </div>
                ))
            }
            <div class="pt-4 flex items-center justify-between px-3">
                <div class="flex items-center gap-4">
                    <button
                        type="button"
                        class="p-2 text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
                        data-theme-toggle
                    >
                        <svg class="theme-icon-moon dark:hidden" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"/></svg>
                        <svg class="theme-icon-sun hidden dark:block" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
                    </button>
                    <LanguagePicker />
                </div>
            </div>
        </div>
    </div>
</header>

<style>
    #mobile-menu-toggle:checked ~ .nav-main-mobile {
        max-height: 100vh;
    }
    #mobile-menu-toggle:checked ~ div label #menu-icon {
        opacity: 0;
        pointer-events: none;
    }
    #mobile-menu-toggle:checked ~ div label #close-icon {
        opacity: 1;
        pointer-events: auto;
    }
</style>

<div class="search-modal" data-search-modal hidden>
    <button
        type="button"
        class="search-backdrop"
        data-search-close
        aria-label={lang === "zh" ? "关闭搜索" : "Close search"}
    ></button>
    <div class="search-panel" role="dialog" aria-modal="true" aria-label={searchLabel}>
        <Search
            id="site-search-modal"
            className="pagefind-ui pagefind-ui-custom"
            uiOptions={{ showImages: false }}
        />
    </div>
</div>
<script>
    const setupSearchModal = () => {
        const modal = document.querySelector("[data-search-modal]");
        if (!modal || modal.getAttribute("data-bound") === "true") return;

        const openBtn = document.querySelector("[data-search-open]");
        const closeBtns = modal.querySelectorAll("[data-search-close]");

        const openModal = () => {
            modal.removeAttribute("hidden");
            document.body.style.overflow = "hidden";
            requestAnimationFrame(() => modal.classList.add("is-open"));
            window.setTimeout(() => {
                const input = modal.querySelector(".pagefind-ui__search-input");
                if (input instanceof HTMLInputElement) input.focus();
            }, 120);
        };

        const closeModal = () => {
            modal.classList.remove("is-open");
            document.body.style.overflow = "";
            window.setTimeout(() => modal.setAttribute("hidden", ""), 180);
        };

        openBtn?.addEventListener("click", openModal);
        closeBtns.forEach((btn) => btn.addEventListener("click", closeModal));
        document.addEventListener("keydown", (event) => {
            if (event.key === "Escape" && !modal.hasAttribute("hidden")) closeModal();
        });
        modal.setAttribute("data-bound", "true");
    };

    const setupThemeToggle = () => {
        const button = document.querySelector("[data-theme-toggle]");
        if (!(button instanceof HTMLButtonElement)) return;
        if (button.getAttribute("data-bound") === "true") return;

        const updateTheme = (isDark: boolean) => {
            if (isDark) {
                document.documentElement.classList.add('dark');
                button.setAttribute("data-theme-resolved", "dark");
                localStorage.setItem('theme', 'dark');
            } else {
                document.documentElement.classList.remove('dark');
                button.setAttribute("data-theme-resolved", "light");
                localStorage.setItem('theme', 'light');
            }
        };

        button.addEventListener("click", () => {
            const isDark = document.documentElement.classList.contains('dark');
            updateTheme(!isDark);
        });

        // Initialize icon state
        const isDark = document.documentElement.classList.contains('dark');
        button.setAttribute("data-theme-resolved", isDark ? "dark" : "light");
        
        button.setAttribute("data-bound", "true");
    };

    document.addEventListener("astro:page-load", setupSearchModal);
    document.addEventListener("astro:page-load", setupThemeToggle);
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", setupSearchModal);
        document.addEventListener("DOMContentLoaded", setupThemeToggle);
    } else {
        setupSearchModal();
        setupThemeToggle();
    }
</script>
