---
// Imports
import {
    getLangFromUrl,
    useTranslations,
    useTranslatedPath,
} from "@i18n/utils";
import { Image } from "astro:assets";
import navigationData from "@data/navigationData";
import logo from "@assets/logo.svg";
import LanguagePicker from "./LanguagePicker.astro";
import Search from "astro-pagefind/components/Search";

// Translations
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const searchLabel = lang === "zh" ? "搜索" : "Search";
const themeLabel = lang === "zh" ? "暗黑模式" : "Theme";
---

<header class="nav-header" role="banner">
    <!-- Mobile menu toggle (CSS only) -->
    <input
        type="checkbox"
        id="mobile-menu-toggle"
        class="mobile-menu-checkbox"
        aria-label="Toggle mobile menu"
    />

    <div class="flex items-center justify-between">
        <a
            href={translatePath("/")}
            class="logo"
            aria-label={t("main.title")}
            tabindex="0"
        >
            <Image
                src={logo}
                alt={t("main.title")}
                loading="eager"
                width={100}
            />
        </a>

        <label for="mobile-menu-toggle" class="mobile-menu-toggle">
            <span></span>
            <span></span>
            <span></span>
        </label>
    </div>

    <nav class="nav-main" role="navigation" aria-label="Main navigation">
        <ul class="nav-list" role="menubar">
            {
                navigationData.map((item) => (
                    <li class="nav-item lg:relative" role="none">
                        <a
                            href={translatePath(item.href)}
                            class="nav-link block"
                            role="menuitem"
                            aria-label={t(item.label)}
                        >
                            {t(item.label)}
                        </a>

                        {item.children?.length > 0 && (
                            <ul
                                class="nav-dropdown"
                                role="menu"
                                aria-label={`${t(item.label)}`}
                            >
                                {item.children.map((child: any) => (
                                    <li role="none">
                                        <a
                                            href={translatePath(child.href)}
                                            class="nav-dropdown-link"
                                            role="menuitem"
                                            aria-label={t(child.label)}
                                        >
                                            {t(child.label)}
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        )}
                    </li>
                ))
            }
        </ul>
        <div class="nav-actions">
            <button
                type="button"
                class="search-trigger"
                data-search-open
                aria-label={searchLabel}
                title={searchLabel}
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <circle cx="11" cy="11" r="8"></circle>
                    <path d="m21 21-4.3-4.3"></path>
                </svg>
            </button>
            <button
                type="button"
                class="theme-trigger"
                data-theme-toggle
                aria-label={themeLabel}
                title={themeLabel}
            >
                <svg
                    class="theme-icon theme-icon-moon"
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"></path>
                </svg>
                <svg
                    class="theme-icon theme-icon-sun"
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <circle cx="12" cy="12" r="4"></circle>
                    <path d="M12 2v2"></path>
                    <path d="M12 20v2"></path>
                    <path d="m4.93 4.93 1.41 1.41"></path>
                    <path d="m17.66 17.66 1.41 1.41"></path>
                    <path d="M2 12h2"></path>
                    <path d="M20 12h2"></path>
                    <path d="m6.34 17.66-1.41 1.41"></path>
                    <path d="m19.07 4.93-1.41 1.41"></path>
                </svg>
            </button>
            <LanguagePicker />
            <a
                href="https://github.com/Scorpio3310/astro-i18n-starter"
                aria-label="GitHub Astro i18n Starter"
                target="_blank"
                rel="noopener noreferrer"
                tabindex="0"
                class="hover:opacity-50"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="28"
                    height="28"
                    viewBox="0 0 16 16"
                    aria-hidden="true"
                    focusable="false"
                >
                    <path
                        fill="currentColor"
                        d="M8 0c4.42 0 8 3.58 8 8a8.01 8.01 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38c0-.27.01-1.13.01-2.2c0-.75-.25-1.23-.54-1.48c1.78-.2 3.65-.88 3.65-3.95c0-.88-.31-1.59-.82-2.15c.08-.2.36-1.02-.08-2.12c0 0-.67-.22-2.2.82c-.64-.18-1.32-.27-2-.27s-1.36.09-2 .27c-1.53-1.03-2.2-.82-2.2-.82c-.44 1.1-.16 1.92-.08 2.12c-.51.56-.82 1.28-.82 2.15c0 3.06 1.86 3.75 3.64 3.95c-.23.2-.44.55-.51 1.07c-.46.21-1.61.55-2.33-.66c-.15-.24-.6-.83-1.23-.82c-.67.01-.27.38.01.53c.34.19.73.9.82 1.13c.16.45.68 1.31 2.69.94c0 .67.01 1.3.01 1.49c0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8"
                    ></path>
                </svg>
            </a>
        </div>
    </nav>
</header>
<div class="search-modal" data-search-modal hidden>
    <button
        type="button"
        class="search-backdrop"
        data-search-close
        aria-label={lang === "zh" ? "关闭搜索" : "Close search"}
    ></button>
    <div class="search-panel" role="dialog" aria-modal="true" aria-label={searchLabel}>
        <Search
            id="site-search-modal"
            className="pagefind-ui pagefind-ui-custom"
            uiOptions={{ showImages: false }}
        />
    </div>
</div>
<script>
    const setupSearchModal = () => {
        const modal = document.querySelector("[data-search-modal]");
        if (!modal || modal.getAttribute("data-bound") === "true") return;

        const openBtn = document.querySelector("[data-search-open]");
        const closeBtns = modal.querySelectorAll("[data-search-close]");

        const openModal = () => {
            modal.removeAttribute("hidden");
            document.body.style.overflow = "hidden";
            requestAnimationFrame(() => modal.classList.add("is-open"));
            window.setTimeout(() => {
                const input = modal.querySelector(".pagefind-ui__search-input");
                if (input instanceof HTMLInputElement) input.focus();
            }, 120);
        };

        const closeModal = () => {
            modal.classList.remove("is-open");
            document.body.style.overflow = "";
            window.setTimeout(() => modal.setAttribute("hidden", ""), 180);
        };

        openBtn?.addEventListener("click", openModal);
        closeBtns.forEach((btn) => btn.addEventListener("click", closeModal));
        document.addEventListener("keydown", (event) => {
            if (event.key === "Escape" && !modal.hasAttribute("hidden")) closeModal();
        });
        modal.setAttribute("data-bound", "true");
    };

    const setupThemeToggle = () => {
        const button = document.querySelector("[data-theme-toggle]");
        if (!(button instanceof HTMLButtonElement)) return;
        if (button.getAttribute("data-bound") === "true") return;

        const updateIcon = () => {
            const resolvedTheme =
                document.documentElement.attributes.getNamedItem("data-theme")?.value ||
                "light";
            button.setAttribute("data-theme-resolved", resolvedTheme);
        };

        button.addEventListener("click", () => {
            const resolvedTheme =
                document.documentElement.attributes.getNamedItem("data-theme")?.value ||
                "light";
            const nextTheme = resolvedTheme === "dark" ? "light" : "dark";
            document.dispatchEvent(
                new CustomEvent("set-theme", {
                    detail: nextTheme,
                })
            );
            window.setTimeout(updateIcon, 0);
        });

        window.addEventListener("storage", updateIcon);
        window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", updateIcon);
        updateIcon();
        button.setAttribute("data-bound", "true");
    };

    document.addEventListener("astro:page-load", setupSearchModal);
    document.addEventListener("astro:page-load", setupThemeToggle);
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", setupSearchModal);
        document.addEventListener("DOMContentLoaded", setupThemeToggle);
    } else {
        setupSearchModal();
        setupThemeToggle();
    }
</script>
