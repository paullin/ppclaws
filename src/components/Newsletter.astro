---
interface Props {
  title: string;
  description: string;
  emailPlaceholder: string;
  buttonText: string;
}

const { title, description, emailPlaceholder, buttonText } = Astro.props;
---

<section class="w-full bg-white dark:bg-astro-card border border-gray-200 dark:border-astro-border rounded-2xl p-8 md:p-12 text-center shadow-sm">
  <div class="max-w-2xl mx-auto">
    <h2 class="text-3xl font-bold mb-4 text-gray-900 dark:text-white">{title}</h2>
    <p class="text-gray-600 dark:text-gray-400 mb-8">{description}</p>
    <form class="flex flex-col sm:flex-row gap-3 justify-center max-w-md mx-auto" onsubmit="event.preventDefault(); alert('Subscription successful!');">
      <input 
        type="email" 
        placeholder={emailPlaceholder} 
        required 
        class="flex-1 px-4 py-3 rounded-lg bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-700 text-gray-900 dark:text-white focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors"
      >
      <button 
        type="submit" 
        class="px-6 py-3 rounded-lg bg-primary hover:bg-primary-hover text-white font-medium transition-colors whitespace-nowrap shadow-sm"
      >
        {buttonText}
      </button>
    </form>
  </div>
</section>
