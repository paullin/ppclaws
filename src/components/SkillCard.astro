---
import { useTranslations } from "@i18n/utils";

interface Props {
    title: string;
    description: string;
    icon?: string;
    cover?: string;
    badge?: string;
    link?: string;
    tags?: string[];
    isFeatured?: boolean;
    lang?: string;
}

const { title, description, icon, cover, badge, link, tags = [], isFeatured = false, lang = "en" } = Astro.props;
const t = useTranslations(lang);

// Badge color logic
const badgeStyles: Record<string, string> = {
    FREE: "bg-emerald-500/10 text-emerald-600 border-emerald-500/20",
    PAID: "bg-orange-500/10 text-orange-600 border-orange-500/20",
    DEFAULT: "bg-slate-500/10 text-slate-600 border-slate-500/20"
};

// Check if badge is 免费 or 付费
let badgeKey = "DEFAULT";
if (badge) {
    if (badge.toUpperCase() === "FREE" || badge === "免费") badgeKey = "FREE";
    else if (badge.toUpperCase() === "PAID" || badge === "付费") badgeKey = "PAID";
}
const currentBadgeStyle = badge ? (badgeStyles[badgeKey] || badgeStyles.DEFAULT) : "";
---

<a 
    href={link || "#"} 
    class="group bg-white dark:bg-astro-card rounded-xl overflow-hidden border border-gray-200 dark:border-astro-border hover:border-primary transition-colors shadow-sm h-full relative flex flex-col"
>
    {isFeatured && (
        <div class="absolute top-3 left-3 z-10 flex items-center justify-center w-8 h-8 rounded-full bg-white/90 dark:bg-gray-900/90 shadow-sm border border-gray-100 dark:border-gray-800 backdrop-blur-sm" title={lang === 'zh' ? '精选' : 'Featured'}>
            <svg class="w-4 h-4 text-red-500 fill-red-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
        </div>
    )}

    {badge && (
        <div class={`absolute top-3 right-3 z-10 px-2.5 py-1 text-xs font-bold rounded-md border ${currentBadgeStyle} backdrop-blur-sm bg-white/80 dark:bg-gray-900/80 uppercase tracking-wider`}>
            {badge}
        </div>
    )}

    {cover ? (
        <div class="aspect-video bg-gray-200 dark:bg-gray-800 overflow-hidden relative">
            <img src={cover} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
        </div>
    ) : icon ? (
        <div class="p-5 pb-0">
            <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-[#8b5cf6]/10 text-primary transition-colors">
                <Fragment set:html={icon} />
            </div>
        </div>
    ) : null}
    
    <div class="p-5 flex flex-col flex-1">
        {tags.length > 0 && (
            <div class="flex items-center gap-2 mb-2 flex-wrap">
                {tags.map(tag => (
                    <span class="px-2 py-0.5 rounded text-[10px] font-semibold bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300">
                        {tag}
                    </span>
                ))}
            </div>
        )}
        
        <h3 class="font-bold text-lg mb-2 text-gray-900 dark:text-white group-hover:text-primary transition-colors line-clamp-1">
            {title}
        </h3>
        
        <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2">
            {description}
        </p>
    </div>
</a>
