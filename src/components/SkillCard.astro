---
import { useTranslations } from "@i18n/utils";

interface Props {
    title: string;
    description: string;
    cover_text?: string;
    cover_theme?: string;
    badge?: string | string[];
    link?: string;
    tags?: string[];
    isFeatured?: boolean;
    lang?: string;
}

const { title, description, cover_text, cover_theme, badge, link, tags = [], isFeatured = false, lang = "en" } = Astro.props;
const t = useTranslations(lang);

// Badge color logic
const badgeStyles: Record<string, string> = {
    NEW: "bg-blue-50 dark:bg-blue-500/10 text-blue-700 dark:text-blue-400 border-blue-100 dark:border-blue-500/20",
    HOT: "bg-red-50 dark:bg-red-500/10 text-red-700 dark:text-red-400 border-red-100 dark:border-red-500/20",
    FREE: "bg-emerald-50 dark:bg-emerald-500/10 text-emerald-700 dark:text-emerald-400 border-emerald-100 dark:border-emerald-500/20",
    PRO: "bg-purple-50 dark:bg-purple-500/10 text-purple-700 dark:text-purple-400 border-purple-100 dark:border-purple-500/20",
    DEFAULT: "bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300 border-gray-200 dark:border-gray-700"
};

// Process badges
let badges: string[] = [];
if (Array.isArray(badge)) {
    badges = badge;
} else if (typeof badge === 'string' && badge.trim() !== '') {
    // Also support comma-separated string just in case
    badges = badge.split(',').map((b: string) => b.trim());
}

// Limit to max 2 badges
const displayBadges = badges.slice(0, 2).map((b: string) => {
    let styleKey = "DEFAULT";
    const bUpper = b.toUpperCase();
    if (bUpper === "NEW" || b === "最新") styleKey = "NEW";
    else if (bUpper === "HOT" || b === "热门") styleKey = "HOT";
    else if (bUpper === "FREE" || b === "免费") styleKey = "FREE";
    else if (bUpper === "PRO" || b === "专业版") styleKey = "PRO";
    
    return {
        text: b,
        style: badgeStyles[styleKey] || badgeStyles.DEFAULT
    };
});

// Theme mapping logic
export const themeMap: Record<string, any> = {
    'light-stone': {
        bg: 'bg-light-stone dark:bg-stone-900 dark:bg-none border-b border-stone-200/50 dark:border-stone-800',
        textBg: 'text-stone-900/5 dark:text-white/5',
        text: 'text-stone-900 dark:text-white',
        tag: 'bg-stone-200/50 dark:bg-stone-500/20 text-stone-700 dark:text-stone-300 border border-stone-300/50 dark:border-stone-500/30',
        hoverTitle: 'group-hover:text-stone-600 dark:group-hover:text-stone-400'
    },
    'light-slate': {
        bg: 'bg-light-slate dark:bg-slate-900 dark:bg-none border-b border-slate-200/50 dark:border-slate-800',
        textBg: 'text-slate-900/5 dark:text-white/5',
        text: 'text-slate-900 dark:text-white',
        tag: 'bg-slate-200/50 dark:bg-slate-500/20 text-slate-700 dark:text-slate-300 border border-slate-300/50 dark:border-slate-500/30',
        hoverTitle: 'group-hover:text-slate-600 dark:group-hover:text-slate-400'
    },
    'light-sand': {
        bg: 'bg-light-sand dark:bg-neutral-900 dark:bg-none border-b border-neutral-200/50 dark:border-neutral-800',
        textBg: 'text-neutral-900/5 dark:text-white/5',
        text: 'text-neutral-900 dark:text-white',
        tag: 'bg-neutral-200/50 dark:bg-neutral-500/20 text-neutral-700 dark:text-neutral-300 border border-neutral-300/50 dark:border-neutral-500/30',
        hoverTitle: 'group-hover:text-neutral-600 dark:group-hover:text-neutral-400'
    },
    'light-mint': {
        bg: 'bg-light-mint dark:bg-emerald-950 dark:bg-none border-b border-emerald-200/50 dark:border-emerald-900',
        textBg: 'text-emerald-900/5 dark:text-white/5',
        text: 'text-emerald-900 dark:text-white',
        tag: 'bg-emerald-200/50 dark:bg-emerald-500/20 text-emerald-800 dark:text-emerald-300 border border-emerald-300/50 dark:border-emerald-500/30',
        hoverTitle: 'group-hover:text-emerald-700 dark:group-hover:text-emerald-400'
    },
    'dark-blue': {
        bg: 'bg-dark-blue border-b border-transparent dark:border-slate-800',
        textBg: 'text-white/5',
        text: 'text-white',
        tag: 'bg-blue-100 dark:bg-slate-800 text-blue-700 dark:text-blue-300 border border-blue-200 dark:border-transparent',
        hoverTitle: 'group-hover:text-blue-600 dark:group-hover:text-blue-400'
    },
    'dark-emerald': {
        bg: 'bg-dark-emerald border-b border-transparent dark:border-emerald-900',
        textBg: 'text-white/5',
        text: 'text-white',
        tag: 'bg-emerald-100 dark:bg-emerald-900 text-emerald-700 dark:text-emerald-300 border border-emerald-200 dark:border-transparent',
        hoverTitle: 'group-hover:text-emerald-600 dark:group-hover:text-emerald-400'
    },
    'dark-purple': {
        bg: 'bg-dark-purple border-b border-transparent dark:border-purple-900',
        textBg: 'text-white/5',
        text: 'text-white',
        tag: 'bg-purple-100 dark:bg-purple-900 text-purple-700 dark:text-purple-300 border border-purple-200 dark:border-transparent',
        hoverTitle: 'group-hover:text-purple-600 dark:group-hover:text-purple-400'
    },
    'dark-rose': {
        bg: 'bg-dark-rose border-b border-transparent dark:border-rose-900',
        textBg: 'text-white/5',
        text: 'text-white',
        tag: 'bg-rose-100 dark:bg-rose-900 text-rose-700 dark:text-rose-300 border border-rose-200 dark:border-transparent',
        hoverTitle: 'group-hover:text-rose-600 dark:group-hover:text-rose-400'
    },
    'dark-green': {
        bg: 'bg-dark-green border-b border-transparent dark:border-green-900',
        textBg: 'text-white/5',
        text: 'text-white',
        tag: 'bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-300 border border-green-200 dark:border-transparent',
        hoverTitle: 'group-hover:text-green-600 dark:group-hover:text-green-400'
    },
    'dark-orange': {
        bg: 'bg-dark-orange border-b border-transparent dark:border-orange-900',
        textBg: 'text-white/5',
        text: 'text-white',
        tag: 'bg-orange-100 dark:bg-orange-900 text-orange-700 dark:text-orange-300 border border-orange-200 dark:border-transparent',
        hoverTitle: 'group-hover:text-orange-600 dark:group-hover:text-orange-400'
    }
};

const getTheme = (themeStr?: string) => {
    if (themeStr && themeMap[themeStr]) return themeMap[themeStr];
    // Simple stable randomizer based on title length
    const themes = Object.keys(themeMap);
    const index = (title.length) % themes.length;
    return themeMap[themes[index]];
};

const currentTheme = getTheme(cover_theme);

// Format cover text:
// If cover_text is explicitly provided, use it (replace spaces with <br> if needed)
// Else, take up to 2 words from title
let displayCoverText = title;
if (cover_text) {
    displayCoverText = cover_text.replace(' ', '<br>');
} else {
    const words = title.split(' ');
    if (words.length >= 2) {
        displayCoverText = words.slice(0, 2).join('<br>');
    }
}

// Extract initials for the background large text
const getInitials = (text: string) => {
    return text.replace(/<[^>]*>?/gm, ' ') // Remove html tags if any
               .split(' ')
               .filter(w => w.length > 0)
               .map(w => w[0])
               .join('')
               .substring(0, 2)
               .toUpperCase();
};
const displayInitials = getInitials(cover_text || title);
---

<a 
    href={link || "#"} 
    class="typography-card group bg-white dark:bg-zinc-900 rounded-2xl overflow-hidden flex flex-col border border-gray-200 dark:border-zinc-800 hover:border-gray-400 dark:hover:border-zinc-600 transition-colors shadow-sm h-full relative"
>
    {displayBadges.length > 0 && (
        <div class="absolute top-4 right-4 z-20 flex gap-2">
            {displayBadges.map(b => (
                <div class={`px-2.5 py-1 text-[10px] font-bold rounded-md border ${b.style} backdrop-blur-sm bg-white/80 dark:bg-zinc-900/80 uppercase tracking-wider`}>
                    {b.text}
                </div>
            ))}
        </div>
    )}

    <!-- 视觉区 (替代原本的 cover / icon) -->
    <div class={`h-52 flex items-end justify-start p-6 relative overflow-hidden transition-colors ${currentTheme.bg}`}>
        <div class={`absolute -top-6 -right-6 text-[7rem] font-black select-none leading-none tracking-tighter transition-colors ${currentTheme.textBg}`}>
            {displayInitials}
        </div>
        <div class={`text-3xl font-bold relative z-10 leading-snug tracking-wide transition-colors ${currentTheme.text}`} set:html={displayCoverText} />
    </div>
    
    <!-- 文本区 -->
    <div class="p-6 flex-1 flex flex-col">
        {tags.length > 0 && (
            <div class="flex items-center gap-2 mb-3 flex-wrap">
                {tags.map(tag => (
                    <span class={`px-2 py-1 rounded text-[10px] font-semibold uppercase tracking-wider transition-colors ${currentTheme.tag}`}>
                        {tag}
                    </span>
                ))}
            </div>
        )}
        
        <h3 class={`text-lg font-bold text-gray-900 dark:text-white mb-2 line-clamp-1 transition-colors ${currentTheme.hoverTitle} min-h-7`}>
            {title}
        </h3>
        
        <p class="text-sm text-gray-500 dark:text-gray-400 line-clamp-2 min-h-10">
            {description}
        </p>
    </div>
</a>