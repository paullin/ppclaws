---
interface Props {
    title: string;
    description: string;
    icon?: string;
    cover?: string;
    link?: string;
    tags?: string[];
}

const { title, description, icon, cover, link, tags = [] } = Astro.props;
---

<a 
    href={link || "#"} 
    class="group flex flex-col bg-white dark:bg-slate-900 rounded-2xl overflow-hidden border border-slate-200/50 dark:border-slate-800/50 hover:border-primary/50 dark:hover:border-primary/50 transition-all duration-300 shadow-sm hover:shadow-xl hover:-translate-y-1 h-full"
>
    {cover ? (
        <div class="aspect-[16/10] bg-slate-100 dark:bg-slate-800 overflow-hidden relative border-b border-slate-100 dark:border-slate-800">
            <img src={cover} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
        </div>
    ) : icon ? (
        <div class="p-6 pb-0">
            <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-primary/10 text-primary group-hover:bg-primary group-hover:text-white transition-colors duration-300">
                <Fragment set:html={icon} />
            </div>
        </div>
    ) : null}
    
    <div class="p-5 flex flex-col flex-1">
        {tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-2">
                {tags.map(tag => (
                    <span class="text-[10px] uppercase tracking-wider font-bold px-1.5 py-0.5 bg-slate-100 dark:bg-slate-800 rounded text-slate-500 dark:text-slate-400">
                        {tag}
                    </span>
                ))}
            </div>
        )}
        
        <h3 class="text-[18px] font-bold text-slate-900 dark:text-white mb-2 group-hover:text-primary transition-colors leading-tight">
            {title}
        </h3>
        
        <p class="text-[14px] text-slate-500 dark:text-slate-400 leading-relaxed line-clamp-2 mb-0">
            {description}
        </p>
    </div>
</a>