---
// Imports
import {
    switchLanguageUrl,
    getLangFromUrl,
    useTranslations,
} from "@i18n/utils";
import { languages } from "@i18n/ui";

// Get current language
const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
const hasLanguageSwitch = Object.keys(languages).length > 1;
const languageFlags: Record<string, string> = {
    en: "🇺🇸",
    zh: "🇨🇳",
};

// Pre-generate URLs for all languages
const languageUrls = await Promise.all(
    Object.entries(languages).map(async ([lang]) => {
        const targetUrl = await switchLanguageUrl(Astro.url, lang);
        const translatedLabel = t(`menu.languages.${lang}`);
        return { lang, label: translatedLabel, targetUrl };
    })
);
---

<!-- // Simple list of links --><!-- <ul>
    {
        languageUrls.map(({ lang, label, targetUrl }) => (
            <li>
                <a href={targetUrl}>{label}</a>
            </li>
        ))
    }
</ul> --><!-- Dropdown selector -->
{
    hasLanguageSwitch && (
        <div class="relative inline-block text-left" data-language-picker>
            <button
                type="button"
                class="inline-flex items-center justify-center p-2 text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
                data-language-toggle
                aria-label={t("menu.languagesText.selectLanguage")}
                aria-haspopup="menu"
                aria-expanded="false"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <circle cx="12" cy="12" r="10"></circle>
                    <path d="M2 12h20"></path>
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                </svg>
            </button>
            <ul 
                class="absolute right-0 bottom-full lg:bottom-auto lg:top-full mb-2 lg:mb-0 lg:mt-1 w-40 rounded-xl border border-gray-200 dark:border-gray-800 bg-white/95 dark:bg-gray-900/95 backdrop-blur-lg shadow-xl py-2 opacity-0 invisible translate-y-2 transition-all duration-200 z-50"
                data-language-menu 
                role="menu"
            >
                {
                    languageUrls.map(({ lang, label, targetUrl }) => (
                        <li role="none">
                            <a
                                href={targetUrl}
                                role="menuitem"
                                class="flex items-center gap-3 px-4 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
                                aria-current={lang === currentLang ? "page" : undefined}
                            >
                                <span class="text-lg" aria-hidden="true">
                                    {languageFlags[lang] || "🌐"}
                                </span>
                                <span class={lang === currentLang ? "font-bold text-primary" : ""}>{label}</span>
                            </a>
                        </li>
                    ))
                }
            </ul>
        </div>
    )
}
<script>
    const setupLanguagePicker = () => {
        const picker = document.querySelector("[data-language-picker]");
        if (!picker || picker.getAttribute("data-bound") === "true") return;

        const toggle = picker.querySelector("[data-language-toggle]");
        const menu = picker.querySelector("[data-language-menu]");
        if (!(toggle instanceof HTMLButtonElement) || !(menu instanceof HTMLElement)) return;

        const closeMenu = () => {
            menu.classList.add("opacity-0", "invisible", "translate-y-2");
            toggle.setAttribute("aria-expanded", "false");
        };

        const openMenu = () => {
            menu.classList.remove("opacity-0", "invisible", "translate-y-2");
            toggle.setAttribute("aria-expanded", "true");
        };

        toggle.addEventListener("click", (e) => {
            e.stopPropagation();
            if (menu.classList.contains("invisible")) {
                openMenu();
            } else {
                closeMenu();
            }
        });

        document.addEventListener("click", (event) => {
            if (!picker.contains(event.target as Node)) {
                closeMenu();
            }
        });

        document.addEventListener("keydown", (event) => {
            if (event.key === "Escape") closeMenu();
        });

        picker.setAttribute("data-bound", "true");
    };

    document.addEventListener("astro:page-load", setupLanguagePicker);
    setupLanguagePicker();
</script>
