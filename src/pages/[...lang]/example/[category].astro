---
import { getCollection } from "astro:content";
import Base from "@layouts/Base.astro";
import SectionGrid from "@components/SectionGrid.astro";
import SkillCard from "@components/SkillCard.astro";
import { useTranslations, useTranslatedPath } from "@i18n/utils";
import ExploreMore from "@components/ExploreMore.astro";

export async function getStaticPaths() {
    const allCategories = await getCollection("exampleCategory");
    
    const paths = [];
    const langs = ["en", "zh"];
    
    for (const lang of langs) {
        const categories = allCategories.filter(c => c.id.startsWith(`${lang}/`));
        for (const category of categories) {
            const categorySlug = category.id.split('/').pop();
            paths.push({
                params: {
                    lang: lang === "en" ? undefined : lang,
                    category: categorySlug,
                },
                props: {
                    lang,
                    category,
                    categorySlug,
                }
            });
        }
    }
    
    return paths;
}

const { lang, category, categorySlug } = Astro.props;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const allExamples = await getCollection("example");
const categoryExamples = allExamples.filter(ex => ex.id.startsWith(`${lang}/`) && ex.data.category === categorySlug);

const allCategories = await getCollection("exampleCategory");
const siblings = allCategories.filter(c => c.id.startsWith(`${lang}/`) && c.id !== category.id).slice(0, 3);
---

<Base 
    title={`${category.data.title} - ${t("common:menu.list.example") || "Example Hub"}`} 
    meta={{ description: category.data.description || "" }}
>
    <div class="py-8 space-y-12 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Breadcrumbs -->
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <nav class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
                <a href={translatePath("/")} class="hover:text-primary transition-colors">{t("common:menu.list.home") || "Home"}</a>
                <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                <a href={translatePath("/example")} class="hover:text-primary transition-colors">{t("common:menu.list.example") || "Example Hub"}</a>
                <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                <span class="text-gray-900 dark:text-white font-medium">{category.data.title}</span>
            </nav>
        </div>

        <div class="space-y-4">
            <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{category.data.title}</h1>
            {category.data.description && (
                <p class="text-lg text-gray-600 dark:text-gray-400 max-w-3xl">{category.data.description}</p>
            )}
        </div>

        <!-- Cards Grid -->
        <SectionGrid columns={4}>
            {categoryExamples.map(ex => {
                const slug = ex.id.split('/').pop();
                return (
                    <SkillCard 
                        title={ex.data.title} 
                        description={ex.data.description || ""}
                        tags={ex.data.tags}
                        cover={ex.data.coverImage}
                        badge={ex.data.badge}
                        link={translatePath(`/example/${categorySlug}/${slug}`)}
                    />
                );
            })}
        </SectionGrid>

        <!-- Related Links Section -->
        {siblings.length > 0 && (
            <section class="pt-16 border-t border-gray-200 dark:border-astro-border">
                <h2 class="text-2xl font-bold tracking-tight mb-6">Explore Other Categories</h2>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
                    {siblings.map(sibling => {
                        const siblingSlug = sibling.id.split('/').pop();
                        return (
                        <a href={translatePath(`/example/${siblingSlug}`)} class="group flex items-center gap-4 p-5 rounded-xl border border-gray-200 dark:border-astro-border hover:border-primary transition-all hover:shadow-lg bg-white dark:bg-astro-card">
                            <div class="w-12 h-12 rounded-lg bg-primary/10 text-primary flex items-center justify-center group-hover:scale-110 transition-transform">
                                <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                            </div>
                            <div class="flex-1">
                                <div class="text-base font-bold group-hover:text-primary transition-colors">{sibling.data.title}</div>
                                {sibling.data.description && (
                                    <div class="text-xs text-gray-500 dark:text-gray-400 mt-1 line-clamp-1">{sibling.data.description}</div>
                                )}
                            </div>
                            <svg class="w-5 h-5 text-gray-400 group-hover:text-primary transition-transform group-hover:translate-x-1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                        </a>
                    )})}
                </div>
            </section>
        )}
    </div>
</Base>