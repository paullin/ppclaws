---
import { getCollection } from "astro:content";
import Base from "@layouts/Base.astro";
import SectionGrid from "@components/SectionGrid.astro";
import SkillCard from "@components/SkillCard.astro";
import { useTranslations, useTranslatedPath } from "@i18n/utils";

export async function getStaticPaths() {
    const langs = ["en", "zh"];
    
    return langs.map(lang => ({
        params: {
            lang: lang === "en" ? undefined : lang,
        },
        props: { lang }
    }));
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const title = lang === 'zh' ? '精选案例' : 'Featured Examples';
const description = lang === 'zh' ? '查看其他人是如何使用 OpenClaw 解决问题的' : 'See what problems people are solving with OpenClaw';

const allExamples = await getCollection("example");
// filter only featured examples for the current lang
const featuredExamples = allExamples.filter(example => example.id.startsWith(`${lang}/`) && example.data.featured);

---

<Base 
    title={`${title} - ${t("common:menu.list.example") || "Example Hub"}`} 
    meta={{ description: description }}
>
    <div class="pt-16 pb-8 space-y-16 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center space-y-4">
            <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl">{title}</h1>
            <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">{description}</p>
        </div>

        <!-- Cards Grid -->
        <SectionGrid columns={4}>
            {featuredExamples.map(example => {
                const slug = example.id.split('/').pop();
                const categorySlug = example.data.category;
                return (
                    <SkillCard 
                        title={example.data.title} 
                        description={example.data.description || ""}
                        tags={example.data.tags}
                        cover={example.data.coverImage}
                            cover_text={example.data.cover_text}
                            cover_theme={example.data.cover_theme}
                        badge={example.data.badge}
                        isFeatured={example.data.featured}
                        lang={lang}
                        link={translatePath(`/example/${categorySlug}/${slug}`)}
                    />
                );
            })}
        </SectionGrid>

        <!-- Related Links Section -->
        <section class="pt-16 border-t border-gray-200 dark:border-astro-border">
            <h2 class="text-2xl font-bold tracking-tight mb-6">{t("common:menu.list.related_content") || "Related Content"}</h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
                <a href={translatePath("/skills/featured")} class="group flex items-center gap-4 p-5 rounded-xl border border-gray-200 dark:border-astro-border hover:border-primary transition-all hover:shadow-lg bg-white dark:bg-astro-card">
                    <div class="w-12 h-12 rounded-lg bg-primary/10 text-primary flex items-center justify-center group-hover:scale-110 transition-transform">
                        <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="M7 21h10"/><path d="M12 3v18"/><path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"/></svg>
                    </div>
                    <div class="flex-1">
                        <div class="text-base font-bold group-hover:text-primary transition-colors">{t("common:menu.list.featured_skills") || "Featured Skills"}</div>
                        <div class="text-xs text-gray-500 dark:text-gray-400 mt-1 line-clamp-1">{t("common:menu.list.explore_skills_desc") || "Explore professional skill packs"}</div>
                    </div>
                    <svg class="w-5 h-5 text-gray-400 group-hover:text-primary transition-transform group-hover:translate-x-1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
            </div>
        </section>

        <div class="pt-8 flex justify-center">
            <a href={translatePath("/example")} class="flex items-center gap-2 px-6 py-3 rounded-full bg-gray-100 dark:bg-gray-800 hover:bg-astro-accent hover:text-white transition-all font-medium text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="m15 18-6-6 6-6"/></svg>
                {lang === 'zh' ? `返回 示例 目录` : `Back to Example Hub`}
            </a>
        </div>
    </div>
</Base>