---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ArticleHeader from '../components/ArticleHeader.astro';
import RelatedLinks from '../components/RelatedLinks.astro';

const breadcrumbsItems = [
  { label: '首页', href: '/' },
  { label: 'Skills 技能中心', href: '/skills' },
  { label: '产品经理 Skills', href: '/skills/product-manager' },
  { label: 'PRD 自动化助手' },
];

const relatedLinks = [
  { label: 'PRD 模板库', href: '#' },
  { label: 'OpenClaw SDK', href: '#' },
  { label: '视频教程', href: '#' },
];

const recommendedLinks = [
  { label: '竞品分析追踪器', href: '#' },
  { label: '产品路线图构建器', href: '#' },
];
---

<Base title="测试页面" meta={{ description: '测试新组件与样式' }}>
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-12">
    <!-- 面包屑导航 -->
    <Breadcrumbs items={breadcrumbsItems} />

    <!-- 详情页头部 -->
    <ArticleHeader 
      title="PRD 自动化助手"
      description="告别繁琐的文档编写工作。PRD 自动化助手基于 AI 技术，只需输入产品核心逻辑和功能大纲，即可在数秒内为您生成结构严谨、内容详实、符合行业标准的 PRD 文档。"
      author="OpenClaw 团队"
      date="2024-04-04"
      tags={['产品经理', '自动化', '文档']}
      coverImage="https://placehold.co/1600x900/f3f4f6/6b7280?text=PRD+Automation+Assistant"
      badge="推荐工具"
    />

    <hr class="border-gray-200 dark:border-astro-border">

    <!-- 正文区域 -->
    <article class="prose dark:prose-invert max-w-none">
      <h2>功能亮点</h2>
      <p>PRD 自动化助手专为解决产品经理在文档编写阶段的痛点而设计，其核心优势包括：</p>
      <ul>
        <li><strong>智能结构化生成</strong>：自动生成包括项目背景、用户角色、功能模块、业务流程图（Mermaid 语法）等在内的标准章节。</li>
        <li><strong>多维度需求拆解</strong>：基于用户的一句话描述，自动拆解为详细的用户故事（User Stories）和验收标准（Acceptance Criteria）。</li>
        <li><strong>交互原型描述</strong>：根据功能逻辑，自动生成详细的页面交互描述，方便设计师与开发理解。</li>
        <li><strong>合规性与边界检查</strong>：自动识别潜在的逻辑漏洞，并提供异常情况（Edge Cases）的处理建议。</li>
      </ul>

      <h2>如何使用</h2>
      <p>仅需简单的三个步骤，即可完成高质量文档的输出：</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 my-8 not-prose">
        <div class="bg-white dark:bg-astro-card p-6 rounded-xl border border-gray-200 dark:border-astro-border">
          <div class="w-10 h-10 rounded-full bg-astro-accent/10 text-astro-accent flex items-center justify-center font-bold mb-4">1</div>
          <h4 class="font-bold mb-2 text-gray-900 dark:text-white">输入核心概念</h4>
          <p class="text-sm text-gray-500">在编辑器中输入产品名称和核心功能点。</p>
        </div>
        <div class="bg-white dark:bg-astro-card p-6 rounded-xl border border-gray-200 dark:border-astro-border">
          <div class="w-10 h-10 rounded-full bg-astro-accent/10 text-astro-accent flex items-center justify-center font-bold mb-4">2</div>
          <h4 class="font-bold mb-2 text-gray-900 dark:text-white">AI 智能生成</h4>
          <p class="text-sm text-gray-500">点击“一键生成”，AI 将自动完成文档扩充与润色。</p>
        </div>
        <div class="bg-white dark:bg-astro-card p-6 rounded-xl border border-gray-200 dark:border-astro-border">
          <div class="w-10 h-10 rounded-full bg-astro-accent/10 text-astro-accent flex items-center justify-center font-bold mb-4">3</div>
          <h4 class="font-bold mb-2 text-gray-900 dark:text-white">导出与协作</h4>
          <p class="text-sm text-gray-500">支持导出为 Markdown、PDF 或同步至飞书文档。</p>
        </div>
      </div>
    </article>

    <!-- 关联资源区域 -->
    <RelatedLinks title="关联资源" links={relatedLinks} />

    <!-- 推荐阅读 -->
    <RelatedLinks title="推荐阅读" links={recommendedLinks} />
    
    <!-- 返回链接 -->
    <div class="pt-8 flex justify-center">
      <a href="/skills/product-manager" class="flex items-center gap-2 px-6 py-3 rounded-full bg-gray-100 dark:bg-gray-800 hover:bg-astro-accent hover:text-white transition-all font-medium text-sm text-gray-900 dark:text-gray-100">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="m15 18-6-6 6-6"/></svg>
        返回产品经理 Skills 列表
      </a>
    </div>
  </main>
</Base>