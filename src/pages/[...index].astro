---
//Imports
import { useTranslations } from "@i18n/utils";
import Base from "@layouts/Base.astro";
import { getEntry } from "astro:content";
import HeroCarousel from "@components/HeroCarousel.svelte";
import SectionHeader from "@components/SectionHeader.astro";
import SectionGrid from "@components/SectionGrid.astro";
import SkillCard from "@components/SkillCard.astro";

// Get current language from URL
export function getStaticPaths() {
    return [
        {
            params: { index: "/" },
            props: { lang: "en" },
        },
        {
            params: { index: "zh/" },
            props: { lang: "zh" },
        },
    ];
}

// Props
const { lang } = Astro.props;

// Translations
const t = useTranslations(lang);

// Determine which json to load based on language
const entryId = lang === "zh" ? "zh" : "en";
const homeEntry = await getEntry("homepage", entryId);
// Fallback to "home" if specific lang entry doesn't exist
const data = homeEntry?.data || (await getEntry("homepage", "home"))?.data;

const heroItems = data?.hero || [];
const sectionTitle = data?.title || "Featured Content";
const homepageSections = data?.sections || [];
---

<Base
    title={t("main:head.title")}
    meta={{
        description: t("main:head.description"),
        keywords: t("main:head.keywords"),
    }}
>
    <div class="max-w-7xl mx-auto px-4 py-8 space-y-24">
        {heroItems.length > 0 && (
            <div class="space-y-6">
                <h2 class="text-2xl font-bold text-gray-900 dark:text-white">{sectionTitle}</h2>
                <HeroCarousel client:load items={heroItems} />
            </div>
        )}

        {homepageSections.map((section) => (
            <section class="max-w-none">
                <SectionHeader 
                    title={section.title} 
                    subtitle={section.subtitle} 
                    moreLink={section.moreLink}
                    moreText={section.moreText}
                />
                <SectionGrid columns={4}>
                    {section.items.map((item) => (
                        <SkillCard 
                            title={item.title} 
                            description={item.description}
                            tags={item.tags}
                            cover={item.cover}
                            link={item.link}
                            icon={item.icon}
                        />
                    ))}
                </SectionGrid>
            </section>
        ))}
    </div>
</Base>
