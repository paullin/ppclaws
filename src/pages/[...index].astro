---
//Imports
import { useTranslations } from "@i18n/utils";
import { showDefaultLang } from "../i18n/ui";
import Base from "@layouts/Base.astro";
import { getCollection, getEntry } from "astro:content";
import HeroCarousel from "@components/HeroCarousel.svelte";
import SectionHeader from "@components/SectionHeader.astro";
import SectionGrid from "@components/SectionGrid.astro";
import SkillCard from "@components/SkillCard.astro";
import SurveySection from "@components/SurveySection.svelte";
import Newsletter from "@components/Newsletter.astro";
import SubmissionForm from "@components/SubmissionForm.svelte";

// Get current language from URL
export function getStaticPaths() {
    return [
        {
            params: { index: undefined },
            props: { lang: "en" },
        },
        {
            params: { index: "zh" },
            props: { lang: "zh" },
        },
    ];
}

// Props
const { lang } = Astro.props;

// Translations
const t = useTranslations(lang);

// Determine which json to load based on language
const entryId = lang === "zh" ? "zh" : "en";
const homepageEntries = await getCollection("homepage");
const homeEntry = homepageEntries.find((entry) => entry.id === entryId || entry.id === `${entryId}.json`);
const data = homeEntry?.data;

const heroItems = data?.hero || [];
const pageTitle = t("main:head.title");
const pageDescription = t("main:head.description");
const homepageSections = data?.sections || [];
const footerData = data?.footer;

const allSkills = await getCollection("skills");
const skills = allSkills.filter(entry => entry.id.startsWith(`${lang}/`));

// Create dynamic sections by merging json config with live skills data
const dynamicSections = homepageSections.map((section: any) => {
    // Map section.id to category slug
    const categoryMap: Record<string, string> = {
        "pm-skills": "product-manager",
        "ux-skills": "ui-ux-designer",
        "marketing-skills": "marketing",
        "dev-skills": "developer"
    };
    
    const categorySlug = categoryMap[section.id];
    let items = section.items || [];
    
    // If it's a known category, fetch the latest 4 skills
    if (categorySlug) {
        const categorySkills = skills
            .filter(skill => skill.data.category === categorySlug || skill.id.split('/')[1] === categorySlug)
            .sort((a, b) => {
                const timeA = a.data.date ? new Date(a.data.date).getTime() : 0;
                const timeB = b.data.date ? new Date(b.data.date).getTime() : 0;
                if (timeB !== timeA) return timeB - timeA;
                return b.id.localeCompare(a.id);
            })
            .slice(0, 4);
            
        if (categorySkills.length > 0) {
            items = categorySkills.map((skill, index) => {
                const slug = skill.id.split('/').pop();
                const prefix = lang === 'en' && !showDefaultLang ? '' : `/${lang}`;
                
                // Add NEW badge dynamically for first 4 items
                let dynamicBadge = skill.data.badge;
                if (index < 4) {
                    if (!dynamicBadge) dynamicBadge = ["NEW"];
                    else if (typeof dynamicBadge === "string" && dynamicBadge.toUpperCase() !== "NEW" && dynamicBadge !== "最新") {
                        dynamicBadge = ["NEW", dynamicBadge];
                    } else if (Array.isArray(dynamicBadge) && !dynamicBadge.some(b => b.toUpperCase() === "NEW" || b === "最新")) {
                        dynamicBadge = ["NEW", ...dynamicBadge];
                    }
                }

                return {
                    title: skill.data.title,
                    description: skill.data.description || "",
                    tags: skill.data.tags || [],
                    cover_text: skill.data.cover_text,
                    cover_theme: skill.data.cover_theme,
                    badge: dynamicBadge,
                    featured: skill.data.featured,
                    link: `${prefix}/skills/${categorySlug}/${slug}`
                };
            });
        }
    }
    
    return {
        ...section,
        items
    };
});
---

<Base
    title={pageTitle}
    meta={{
        description: pageDescription,
        keywords: t("main:head.keywords"),
    }}
    footerData={footerData}
>
    <h1 class="sr-only">{pageTitle}</h1>
    <div class="py-8 space-y-16">
        {heroItems.length > 0 && (
            <div class="w-full">
                <HeroCarousel client:load items={heroItems} />
            </div>
        )}

        {dynamicSections.slice(0, 4).map((section: any) => (
            <section 
                id={section.id} 
                class="max-w-none scroll-mt-20"
            >
                <SectionHeader 
                    title={section.title} 
                    subtitle={section.subtitle} 
                    moreLink={section.moreLink}
                    moreText={section.moreText}
                />
                <SectionGrid columns={section.columns as 1 | 2 | 4}>
                    {section.items.map((item: any) => (
                        <SkillCard 
                            title={item.title} 
                            description={item.description}
                            tags={item.tags}
                            cover_text={item.cover_text}
                            cover_theme={item.cover_theme}
                            badge={item.badge}
                            link={item.link}
                            isFeatured={item.featured}
                            lang={lang}
                        />
                    ))}
                </SectionGrid>
            </section>
        ))}

        {data?.newsletter && (
            <Newsletter 
                title={data.newsletter.title}
                description={data.newsletter.description}
                emailPlaceholder={data.newsletter.emailPlaceholder}
                buttonText={data.newsletter.buttonText}
            />
        )}

        {homepageSections.slice(4).map((section: any) => (
            <section 
                id={section.id || "featured-cases"}
                class="max-w-none scroll-mt-20"
            >
                <SectionHeader 
                    title={section.title} 
                    subtitle={section.subtitle} 
                    moreLink={section.moreLink}
                    moreText={section.moreText}
                />
                <SectionGrid columns={section.columns as 1 | 2 | 4}>
                    {section.items.map((item: any) => (
                        <SkillCard 
                            title={item.title} 
                            description={item.description}
                            tags={item.tags}
                            cover_text={item.cover_text}
                            cover_theme={item.cover_theme}
                            badge={item.badge}
                            link={item.link}
                            isFeatured={item.featured}
                            lang={lang}
                        />
                    ))}
                </SectionGrid>
            </section>
        ))}

        <div class="w-full">
            <SurveySection 
                client:load 
                title={lang === 'zh' ? '帮助我们改进' : 'Help Us Improve'}
                description={lang === 'zh' ? '告诉我们您对 OpenClaw 的使用体验，以便我们为您提供更好的内容。' : 'Tell us about your experience with OpenClaw to help us create better content for you.'}
                buttonText={lang === 'zh' ? '参与问卷' : 'Take the Survey'}
                tagText="Research"
            />
        </div>

        {data?.submission && (
            <div class="w-full">
                <SubmissionForm 
                    client:load
                    title={data.submission.title}
                    description={data.submission.description}
                    labels={data.submission.labels}
                    placeholders={data.submission.placeholders}
                    types={data.submission.types}
                />
            </div>
        )}
    </div>
</Base>
