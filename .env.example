# Set your production domain here for SEO
# This ensures search engines only index your production site, not staging/dev environments
# Replace with your actual domain: https://your-production-domain.com
PRODUCTION_DOMAIN = "https://your-domain.com"
PUBLIC_GISCUS_REPO = "owner/repo"
PUBLIC_GISCUS_REPO_ID = "R_xxx"
PUBLIC_GISCUS_CATEGORY = "General"
PUBLIC_GISCUS_CATEGORY_ID = "DIC_xxx"
PUBLIC_GISCUS_MAPPING = "pathname"
PUBLIC_GISCUS_STRICT = "0"
PUBLIC_GISCUS_REACTIONS_ENABLED = "1"
PUBLIC_GISCUS_EMIT_METADATA = "0"
PUBLIC_GISCUS_INPUT_POSITION = "top"
PUBLIC_GISCUS_THEME = "preferred_color_scheme"
PUBLIC_GISCUS_LANG = "zh-CN"
PUBLIC_GISCUS_LOADING = "lazy"
PUBLIC_GISCUS_CROSSORIGIN = "anonymous"
